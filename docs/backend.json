{
  "entities": {
    "StockItem": {
      "title": "Stock Item",
      "type": "object",
      "description": "An item in the stock/inventory.",
      "properties": {
        "nome": { "type": "string" },
        "preco": { "type": "number" },
        "peso": { "type": "number" },
        "unidade": { "type": "string" },
        "categoria": {
          "type": "string",
          "description": "A categoria do item de estoque.",
          "enum": ["Ingrediente", "Material", "Consumo"]
        },
        "dataAtualizacao": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "preco", "peso", "unidade", "categoria", "dataAtualizacao"]
    },
    "RecipeIngredient": {
      "title": "Recipe Ingredient",
      "type": "object",
      "description": "Represents an ingredient used in a recipe, linking to a stock item.",
      "properties": {
        "stockItemId": { "type": "string" },
        "nome": { "type": "string" },
        "quantidadeUsada": { "type": "number" }
      },
      "required": ["stockItemId", "nome", "quantidadeUsada"]
    },
    "DoughRecipe": {
      "title": "Dough Recipe",
      "type": "object",
      "description": "A recipe for a dough/base.",
      "properties": {
        "nome": { "type": "string" },
        "ingredientes": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/RecipeIngredient" }
        },
        "rendimento": { "type": "number" },
        "custoTotal": { "type": "number" },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "ingredientes", "rendimento", "custoTotal", "dataCriacao"]
    },
    "FillingRecipe": {
      "title": "Filling Recipe",
      "type": "object",
      "description": "A recipe for a filling.",
      "properties": {
        "nome": { "type": "string" },
        "ingredientes": {
          "type": "array",
          "items": { "$ref": "#/backend/entities/RecipeIngredient" }
        },
        "rendimento": { "type": "number" },
        "custoTotal": { "type": "number" },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "ingredientes", "rendimento", "custoTotal", "dataCriacao"]
    },
    "FinalProduct": {
      "title": "Final Product",
      "type": "object",
      "description": "A final product for sale, composed of other recipes.",
      "properties": {
        "nome": { "type": "string" },
        "massaId": { "type": "string" },
        "nomeMassa": { "type": "string" },
        "recheioId": { "type": ["string", "null"] },
        "nomeRecheio": { "type": ["string", "null"] },
        "materialPercentage": {
          "type": "number",
          "description": "Percentage cost added for materials."
        },
        "consumoPercentage": {
          "type": "number",
          "description": "Percentage cost added for consumables."
        },
        "quantidadeFinal": { "type": "number" },
        "custoTotal": { "type": "number" },
        "custoUnitario": { "type": "number" },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "massaId", "nomeMassa", "quantidadeFinal", "custoTotal", "custoUnitario", "dataCriacao"]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/estoque/{itemId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/StockItem" },
          "description": "Stores individual inventory items."
        }
      },
      {
        "path": "/receitas_massa/{massaId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/DoughRecipe" },
          "description": "Stores recipes for doughs/bases."
        }
      },
      {
        "path": "/receitas_recheio/{recheioId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/FillingRecipe" },
          "description": "Stores recipes for fillings."
        }
      },
      {
        "path": "/produtos_finais/{produtoId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/FinalProduct" },
          "description": "Stores final, sellable products."
        }
      }
    ]
  }
}
