rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public access for all collections as per no-login requirement.
    
    match /estoque/{itemId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if resource != null;
    }

    match /receitas_massa/{massaId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if resource != null;
    }

    match /receitas_recheio/{recheioId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if resource != null;
    }

    match /produtos_finais/{produtoId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if resource != null;
    }
  }
}
